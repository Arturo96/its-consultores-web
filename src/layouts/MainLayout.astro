---
export interface Props {
	title?: string;
	description?: string;
}

const {
	title = "IT & Security Consultores",
	description = "Portal corporativo de IT & Security Consultores enfocado en servicios B2B de ciberseguridad en Colombia.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>
