---
import { solutionCategories } from "../data/solutions";

const links = [
	{ href: "/nosotros", label: "Quienes Somos" },
	{ href: "/servicios", label: "Servicios" },
	{ href: "/contacto", label: "Contacto" },
];

const { currentPath = "/" } = Astro.props;
const isSolutionsActive = currentPath.startsWith("/soluciones");
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-white/10 bg-[rgba(0,18,51,0.7)] backdrop-blur-xl">
	<div class="mx-auto flex max-w-7xl items-center justify-between px-5 py-4 md:px-8 lg:px-10">
		<a href="/" class="flex items-center gap-3" aria-label="Ir al inicio de IT & Security Consultores">
			<img
				src="/images/it-security-sas.png"
				alt="Logo de IT & Security Consultores"
				class="h-10 w-auto object-contain md:h-11"
			/>
		</a>

		<nav aria-label="Navegacion principal" class="hidden items-center gap-2 md:flex">
			<div class="group relative">
				<a
					href="/soluciones"
					class:list={[
						"inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm font-semibold text-white/72",
						"hover:bg-white/8 hover:text-[var(--color-primary)]",
						isSolutionsActive && "bg-white/8 text-[var(--color-primary)]",
					]}
				>
					<span>Soluciones</span>
					<svg
						viewBox="0 0 20 20"
						fill="none"
						aria-hidden="true"
						class="h-4 w-4 transition-transform duration-200 group-hover:rotate-180"
					>
						<path
							d="M5 7.5L10 12.5L15 7.5"
							stroke="currentColor"
							stroke-width="1.6"
							stroke-linecap="round"
							stroke-linejoin="round"
						></path>
					</svg>
				</a>

				<div class="pointer-events-none absolute left-0 top-full pt-4 opacity-0 transition duration-200 group-hover:pointer-events-auto group-hover:opacity-100">
					<div class="w-[24rem] rounded-[1.5rem] border border-cyan-300/12 bg-[rgba(3,18,48,0.96)] p-4 shadow-[0_22px_60px_rgba(0,10,30,0.55)] backdrop-blur-xl">
						<div class="grid gap-3">
							{
								solutionCategories.map((category) => (
									<div class="rounded-2xl border border-white/8 bg-[rgba(9,28,64,0.92)] p-4">
										<a
											href={category.path}
											class="text-sm font-extrabold uppercase tracking-[0.16em] text-[var(--color-primary)]"
										>
											{category.name}
										</a>
										<ul class="mt-3 space-y-2">
											{
												category.items.map((item) => (
													<li>
														<a
															href={item.path}
															class="block text-sm text-white/72 hover:text-white"
														>
															{item.name}
														</a>
													</li>
												))
											}
										</ul>
									</div>
								))
							}
						</div>
					</div>
				</div>
			</div>

			{
				links.map(({ href, label }) => {
					const isActive = currentPath === href;

					return (
						<a
							href={href}
							class:list={[
								"rounded-full px-4 py-2 text-sm font-semibold text-white/72",
								"hover:bg-white/8 hover:text-[var(--color-primary)]",
								isActive && "bg-white/8 text-[var(--color-primary)]",
							]}
						>
							{label}
						</a>
					);
				})
			}
		</nav>

		<details class="relative md:hidden">
			<summary class="flex h-11 w-11 cursor-pointer items-center justify-center rounded-full border border-white/12 bg-white/6 text-white marker:content-none">
				<span class="sr-only">Abrir menu</span>
				<span class="flex flex-col gap-1.5">
					<span class="h-0.5 w-5 rounded-full bg-current"></span>
					<span class="h-0.5 w-5 rounded-full bg-current"></span>
					<span class="h-0.5 w-5 rounded-full bg-current"></span>
				</span>
			</summary>

			<div class="absolute right-0 top-full mt-4 w-[min(22rem,calc(100vw-2.5rem))] rounded-[1.5rem] border border-cyan-300/12 bg-[rgba(3,18,48,0.98)] p-4 shadow-[0_22px_60px_rgba(0,10,30,0.55)] backdrop-blur-xl">
				<div class="space-y-2">
					<a
						href="/soluciones"
						class:list={[
							"block rounded-2xl px-4 py-3 text-sm font-semibold text-white/78",
							"hover:bg-white/8 hover:text-[var(--color-primary)]",
							isSolutionsActive && "bg-white/8 text-[var(--color-primary)]",
						]}
					>
						Soluciones
					</a>

					<details class="rounded-2xl border border-white/8 bg-[rgba(9,28,64,0.92)]">
						<summary class="cursor-pointer list-none px-4 py-3 text-sm font-semibold text-white/78">
							<div class="flex items-center justify-between gap-3">
								<span>Ver categorias</span>
								<svg viewBox="0 0 20 20" fill="none" aria-hidden="true" class="h-4 w-4">
									<path
										d="M5 7.5L10 12.5L15 7.5"
										stroke="currentColor"
										stroke-width="1.6"
										stroke-linecap="round"
										stroke-linejoin="round"
									></path>
								</svg>
							</div>
						</summary>

						<div class="space-y-3 px-3 pb-3">
							{
								solutionCategories.map((category) => (
									<div class="rounded-2xl border border-white/8 bg-[rgba(5,21,52,0.95)] p-3">
										<a
											href={category.path}
											class="block text-xs font-extrabold uppercase tracking-[0.16em] text-[var(--color-primary)]"
										>
											{category.name}
										</a>
										<ul class="mt-3 space-y-2">
											{
												category.items.map((item) => (
													<li>
														<a
															href={item.path}
															class="block rounded-xl px-2 py-1 text-sm text-white/72 hover:bg-white/6 hover:text-white"
														>
															{item.name}
														</a>
													</li>
												))
											}
										</ul>
									</div>
								))
							}
						</div>
					</details>

					{
						links.map(({ href, label }) => {
							const isActive = currentPath === href;

							return (
								<a
									href={href}
									class:list={[
										"block rounded-2xl px-4 py-3 text-sm font-semibold text-white/78",
										"hover:bg-white/8 hover:text-[var(--color-primary)]",
										isActive && "bg-white/8 text-[var(--color-primary)]",
									]}
								>
									{label}
								</a>
							);
						})
					}

				</div>
			</div>
		</details>
	</div>
</header>
