---
interface Props {
	eyebrow: string;
	title: string;
	description: string;
	highlights: string[];
	ctaLabel?: string;
	secondaryHref?: string;
	secondaryLabel?: string;
}

const {
	eyebrow,
	title,
	description,
	highlights,
	ctaLabel = "Contáctanos",
	secondaryHref = "/contacto",
	secondaryLabel = "Solicitar asesoria",
} = Astro.props;
---

<section class="section-shell overflow-hidden px-5 py-16 md:px-8 md:py-20 lg:px-10">
	<div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
		<div>
			<div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-[var(--color-chip)] px-4 py-2 text-[11px] font-bold uppercase tracking-[0.2em] text-white/85">
				<span class="h-2 w-2 rounded-full bg-[var(--color-primary)]"></span>
				{eyebrow}
			</div>

			<h1 class="mt-6 max-w-3xl text-4xl font-extrabold leading-tight text-white md:text-5xl lg:text-6xl">
				{title}
			</h1>

			<p class="mt-6 max-w-2xl text-base leading-8 text-[var(--color-muted)] md:text-lg">
				{description}
			</p>

			<div class="mt-10 flex flex-col gap-4 sm:flex-row">
				<a href="#contacto" class="btn-primary px-7 py-4 text-base">
					{ctaLabel}
				</a>
				<a href={secondaryHref} class="btn-secondary px-7 py-4 text-base font-semibold text-white">
					{secondaryLabel}
				</a>
			</div>
		</div>

		<div class="glass-card rounded-[1.8rem] p-7 md:p-8">
			<p class="text-sm font-extrabold uppercase tracking-[0.24em] text-[var(--color-primary)]">
				Capacidades clave
			</p>
			<ul class="mt-6 space-y-4">
				{
					highlights.map((highlight, index) => (
						<li class="flex gap-4 rounded-2xl border border-white/8 bg-white/4 px-4 py-4">
							<div class="mt-1 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-cyan-400/10 text-xs font-extrabold text-[var(--color-primary)]">
								0{index + 1}
							</div>
							<p class="text-sm leading-7 text-white/76">{highlight}</p>
						</li>
					))
				}
			</ul>
		</div>
	</div>
</section>
