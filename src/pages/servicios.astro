---
import MainLayout from "../layouts/MainLayout.astro";

const highlights = [
	"Servicios diseñados para reducir riesgo operativo y fortalecer la continuidad del negocio.",
	"Acompañamiento consultivo antes, durante y después de cada implementación.",
	"Enfoque B2B para empresas que requieren prevención, control y respuesta efectiva.",
];

const services = [
	{
		label: "01",
		title: "Auditorías de Seguridad Informática",
		description:
			"Detección y corrección proactiva de fallas de seguridad y vulnerabilidades visibles o latentes, existentes en la infraestructura de seguridad informática actual de la red de datos de la empresa.",
	},
	{
		label: "02",
		title: "Acompañamiento Postventa",
		description:
			"Brindamos seguimiento continuo después de la implementación, asegurando el correcto funcionamiento de las soluciones, asesoría ante cambios tecnológicos y apoyo comercial en renovaciones y ampliaciones.",
	},
	{
		label: "03",
		title: "Charlas y Capacitaciones en Ciberseguridad",
		description:
			"Capacitación y concientización de usuarios finales internos de las empresas en buenas prácticas de seguridad de la información.",
	},
	{
		label: "04",
		title: "Implementación de Políticas de Ciberseguridad",
		description:
			"Ayudamos a nuestros clientes a diseñar, implementar y verificar el cumplimiento de políticas de seguridad informática.",
	},
	{
		label: "05",
		title: "Administración y Monitoreo de Seguridad",
		description:
			"Gestionamos y supervisamos de forma continua sus soluciones de seguridad informática, asegurando su correcto funcionamiento, optimización permanente y reducción de riesgos para proteger la continuidad de su negocio.",
	},
	{
		label: "06",
		title: "Seguridad Informática Multinivel como Servicio",
		description:
			"Ofrecemos la implementación del sistema de seguridad informática multinivel propuesto por nuestra compañía como servicio o mediante arrendamiento mensual.",
	},
];
---

<MainLayout
	title="Servicios | IT & Security Consultores"
	description="Servicios de ciberseguridad para empresas en Colombia: auditorías, acompañamiento, capacitación, políticas, monitoreo y seguridad multinivel como servicio."
>
	<section class="section-shell overflow-hidden px-5 py-16 md:px-8 md:py-20 lg:px-10">
		<div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
			<div>
				<h1 class="mt-6 max-w-3xl text-4xl font-extrabold leading-tight text-white md:text-5xl lg:text-6xl">
					Nuestros servicios
				</h1>

				<p class="mt-6 max-w-2xl text-base leading-8 text-[var(--color-muted)] md:text-lg">
					Acompañamos a empresas que necesitan fortalecer su postura de seguridad con servicios
					especializados, enfoque consultivo y ejecución orientada a resultados.
				</p>

				<p class="mt-5 max-w-2xl text-base leading-8 text-[var(--color-muted)]">
					Integramos evaluación, implementación, acompañamiento y monitoreo para ayudar a su
					organización a reducir riesgos, mejorar su capacidad de respuesta y proteger la
					continuidad operativa.
				</p>

				<div class="mt-10 flex flex-col gap-4 sm:flex-row">
					<a href="#contacto" class="btn-primary px-7 py-4 text-base">Contáctanos</a>
				</div>
			</div>

			<div class="glass-card rounded-[1.8rem] p-7 md:p-8">
				<p class="text-sm font-extrabold uppercase tracking-[0.24em] text-[var(--color-primary)]">
					Lo que ofrecemos
				</p>
				<ul class="mt-6 space-y-4">
					{
						highlights.map((highlight, index) => (
							<li class="flex gap-4 rounded-2xl border border-white/8 bg-white/4 px-4 py-4">
								<div class="mt-1 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-cyan-400/10 text-xs font-extrabold text-[var(--color-primary)]">
									0{index + 1}
								</div>
								<p class="text-sm leading-7 text-white/76">{highlight}</p>
							</li>
						))
					}
				</ul>
			</div>
		</div>
	</section>

	<section class="px-5 pb-20 md:px-8 lg:px-10">
		<div class="mx-auto max-w-7xl">
			<div class="glass-card rounded-[2rem] p-7 md:p-10">
				<div class="grid gap-6 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
					<div>
						<p class="text-sm font-extrabold uppercase tracking-[0.24em] text-[var(--color-primary)]">
							Enfoque de servicio
						</p>
						<h2 class="mt-4 text-3xl font-extrabold text-white md:text-4xl">
							Servicios pensados para proteger la operación y acompañar decisiones críticas.
						</h2>
					</div>

					<div class="space-y-5 text-base leading-8 text-[var(--color-muted)]">
						<p>
							Nuestro portafolio responde a necesidades reales de las empresas: identificar
							vulnerabilidades, fortalecer controles, capacitar usuarios, definir políticas y
							asegurar el desempeño continuo de las soluciones de seguridad.
						</p>
						<p>
							Cada servicio se presta con una visión práctica y corporativa, alineada con el
							contexto tecnológico, operativo y comercial de cada organización.
						</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="px-5 pb-20 md:px-8 lg:px-10">
		<div class="mx-auto max-w-7xl">
			<div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
				{
					services.map((service) => (
						<article class="glass-card rounded-[1.7rem] p-7 md:p-8">
							<div class="flex h-12 w-12 items-center justify-center rounded-full bg-[rgba(0,18,51,0.48)] text-sm font-extrabold text-[var(--color-primary)] ring-1 ring-white/10">
								{service.label}
							</div>
							<h2 class="mt-6 text-2xl font-extrabold text-white">{service.title}</h2>
							<p class="mt-4 text-sm leading-8 text-[var(--color-muted)]">{service.description}</p>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<section class="px-5 pb-20 md:px-8 lg:px-10">
		<div class="glass-card mx-auto max-w-6xl rounded-[2rem] px-7 py-10 md:px-12 md:py-12">
			<div class="grid gap-8 md:grid-cols-[1fr_auto] md:items-center">
				<div>
					<p class="text-sm font-extrabold uppercase tracking-[0.28em] text-[var(--color-primary)]">
						Conversemos
					</p>
					<h2 class="mt-3 text-3xl font-extrabold text-white md:text-4xl">
						Definamos el servicio que mejor se ajusta a la realidad de su empresa.
					</h2>
					<p class="mt-4 max-w-3xl text-base leading-7 text-[var(--color-muted)]">
						Si busca auditoría, acompañamiento, capacitación o monitoreo continuo, podemos
						ayudarle a priorizar el siguiente paso y construir una ruta clara de protección.
					</p>
				</div>

				<a href="#contacto" class="btn-primary px-7 py-4 text-base">Contáctanos</a>
			</div>
		</div>
	</section>
</MainLayout>
