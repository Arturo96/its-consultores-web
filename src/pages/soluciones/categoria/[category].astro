---
import MainLayout from "../../../layouts/MainLayout.astro";
import SolutionHero from "../../../components/SolutionHero.astro";
import { getCategoryBySlug, solutionCategories } from "../../../data/solutions";

export function getStaticPaths() {
	return solutionCategories.map((category) => ({
		params: { category: category.slug },
		props: { category },
	}));
}

const { category } = Astro.props;

if (!category || !getCategoryBySlug(category.slug)) {
	throw new Error("Categoria de solucion no encontrada.");
}
---

<MainLayout title={`${category.name} | IT & Security Consultores`} description={category.description}>
	<SolutionHero
		eyebrow="Categoria de soluciones"
		title={category.name}
		description={category.description}
		highlights={category.highlights}
		secondaryHref="/soluciones"
		secondaryLabel="Ver portafolio"
	/>

	<section class="px-5 pb-20 md:px-8 lg:px-10">
		<div class="mx-auto max-w-7xl">
			<div class="glass-card rounded-[1.8rem] p-7 md:p-9">
				<div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
					<div>
						<p class="text-sm font-extrabold uppercase tracking-[0.24em] text-[var(--color-primary)]">
							Soluciones disponibles
						</p>
						<h2 class="mt-3 text-3xl font-extrabold text-white">Tecnologias incluidas en esta categoria</h2>
					</div>
					<p class="max-w-2xl text-sm leading-7 text-[var(--color-muted)]">
						Seleccione la tecnologia que mejor se ajuste a sus necesidades y conversemos por WhatsApp sobre licenciamiento, implementacion y acompanamiento.
					</p>
				</div>

				<div class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
					{
						category.items.map((item) => (
							<article class="rounded-[1.5rem] border border-white/8 bg-white/4 p-6">
								<h3 class="text-xl font-bold text-white">{item.name}</h3>
								<p class="mt-4 text-sm leading-7 text-white/68">{item.description}</p>
								<a href={item.path} class="mt-6 inline-flex text-sm font-semibold text-[var(--color-primary)]">
									Conocer esta solucion
								</a>
							</article>
						))
					}
				</div>
			</div>
		</div>
	</section>
</MainLayout>
