---
import MainLayout from "../../layouts/MainLayout.astro";
import SolutionHero from "../../components/SolutionHero.astro";
import { allSolutions, getSolutionBySlug } from "../../data/solutions";

export function getStaticPaths() {
	return allSolutions.map((solution) => ({
		params: { solution: solution.slug },
		props: { solution },
	}));
}

const { solution } = Astro.props;

if (!solution || !getSolutionBySlug(solution.slug)) {
	throw new Error("Solucion no encontrada.");
}
---

<MainLayout title={`${solution.name} | IT & Security Consultores`} description={solution.description}>
	<SolutionHero
		eyebrow={solution.categoryName}
		title={solution.name}
		description={solution.description}
		highlights={solution.highlights}
		secondaryHref={solution.categoryPath}
		secondaryLabel="Ver categoria"
	/>

	<section class="px-5 pb-20 md:px-8 lg:px-10">
		<div class="mx-auto grid max-w-7xl gap-6 lg:grid-cols-[1.1fr_0.9fr]">
			<article class="glass-card rounded-[1.8rem] p-7 md:p-9">
				<p class="text-sm font-extrabold uppercase tracking-[0.24em] text-[var(--color-primary)]">
					Enfoque empresarial
				</p>
				<h2 class="mt-4 text-3xl font-extrabold text-white">Una conversacion comercial orientada a su realidad operativa</h2>
				<p class="mt-5 text-base leading-8 text-[var(--color-muted)]">
					Le ayudamos a evaluar esta solucion segun el tamano de su organizacion, su entorno tecnologico y las prioridades de riesgo que hoy necesita atender.
				</p>

				<div class="mt-8 grid gap-4 md:grid-cols-3">
					<div class="rounded-2xl border border-white/8 bg-white/4 px-5 py-5">
						<p class="text-sm font-extrabold uppercase tracking-[0.18em] text-[var(--color-primary)]">Evaluacion</p>
						<p class="mt-3 text-sm leading-7 text-white/70">Revisamos alcance, cobertura requerida y contexto de negocio.</p>
					</div>
					<div class="rounded-2xl border border-white/8 bg-white/4 px-5 py-5">
						<p class="text-sm font-extrabold uppercase tracking-[0.18em] text-[var(--color-primary)]">Implementacion</p>
						<p class="mt-3 text-sm leading-7 text-white/70">Acompanamos despliegue, configuracion y buenas practicas operativas.</p>
					</div>
					<div class="rounded-2xl border border-white/8 bg-white/4 px-5 py-5">
						<p class="text-sm font-extrabold uppercase tracking-[0.18em] text-[var(--color-primary)]">Continuidad</p>
						<p class="mt-3 text-sm leading-7 text-white/70">Buscamos adopcion sostenida y resultados medibles para la empresa.</p>
					</div>
				</div>
			</article>

			<aside class="glass-card rounded-[1.8rem] p-7 md:p-9">
				<p class="text-sm font-extrabold uppercase tracking-[0.24em] text-[var(--color-primary)]">
					Categoria relacionada
				</p>
				<h2 class="mt-4 text-2xl font-extrabold text-white">{solution.categoryName}</h2>
				<p class="mt-4 text-sm leading-7 text-[var(--color-muted)]">{solution.categoryDescription}</p>

				<ul class="mt-6 space-y-3">
					{
						allSolutions
							.filter((item) => item.categorySlug === solution.categorySlug)
							.map((item) => (
								<li>
									<a
										href={item.path}
										class:list={[
											"flex items-center justify-between gap-3 rounded-2xl border px-4 py-3 text-sm",
											item.slug === solution.slug
												? "border-cyan-300/25 bg-cyan-400/8 text-white"
												: "border-white/8 bg-white/4 text-white/72 hover:text-[var(--color-primary)]",
										]}
									>
										<span>{item.name}</span>
										<span class="font-semibold">Ver</span>
									</a>
								</li>
							))
					}
				</ul>
			</aside>
		</div>
	</section>
</MainLayout>
